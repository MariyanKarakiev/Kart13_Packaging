---
import { t, type Lang } from '../../i18n/translations';
import { getLocalePath } from '../../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
---

<!-- Hero -->
<section class="relative h-[40vh] min-h-[350px] flex items-center">
  <div class="absolute inset-0">
    <img src="https://images.unsplash.com/photo-1676451727332-790e79f6cc59?fm=jpg&q=80&w=1920&auto=format&fit=crop" alt="" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-[#2d3a2e]/80"></div>
  </div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h1 class="text-4xl md:text-5xl font-bold text-white">{t(lang, 'contact.hero.title')}</h1>
    <p class="mt-4 text-lg text-gray-200 max-w-xl">{t(lang, 'contact.hero.desc')}</p>
  </div>
</section>

<!-- Contact cards -->
<section class="py-16 bg-[#faf9f6]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid sm:grid-cols-3 gap-6 -mt-24 relative z-10">
      <div class="bg-white rounded-lg p-8 shadow-lg text-center" data-aos="fade-up" data-aos-delay="0">
        <div class="w-12 h-12 bg-[#c67a4a]/10 rounded-lg flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-[#c67a4a]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        </div>
        <h3 class="font-bold text-[#2d3a2e]">{t(lang, 'contact.phone')}</h3>
        <p class="text-[#6b6560] mt-2">+359 XXX XXX XXX</p>
        <p class="text-xs text-[#6b6560] mt-1">{t(lang, 'contact.phone.hours')}</p>
      </div>
      <div class="bg-white rounded-lg p-8 shadow-lg text-center" data-aos="fade-up" data-aos-delay="100">
        <div class="w-12 h-12 bg-[#c67a4a]/10 rounded-lg flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-[#c67a4a]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
        </div>
        <h3 class="font-bold text-[#2d3a2e]">{t(lang, 'contact.email')}</h3>
        <p class="text-[#6b6560] mt-2">info@kart13.bg</p>
        <p class="text-xs text-[#6b6560] mt-1">{t(lang, 'contact.email.reply')}</p>
      </div>
      <div class="bg-white rounded-lg p-8 shadow-lg text-center" data-aos="fade-up" data-aos-delay="200">
        <div class="w-12 h-12 bg-[#c67a4a]/10 rounded-lg flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-[#c67a4a]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        </div>
        <h3 class="font-bold text-[#2d3a2e]">{t(lang, 'contact.location')}</h3>
        <p class="text-[#6b6560] mt-2">{t(lang, 'contact.location.value')}</p>
        <p class="text-xs text-[#6b6560] mt-1">{t(lang, 'contact.location.visit')}</p>
      </div>
    </div>
  </div>
</section>

<!-- Form + Map -->
<section class="py-16 bg-[#faf9f6]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-14">
      <div data-aos="fade-right">
        <span class="text-[#c67a4a] font-semibold text-sm uppercase tracking-wide">{t(lang, 'contact.form.label')}</span>
        <h2 class="text-2xl font-bold text-[#2d3a2e] mt-2 mb-6">{t(lang, 'contact.form.title')}</h2>
        <form class="space-y-5">
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="name" class="block text-sm font-medium text-[#2d3a2e] mb-1">{t(lang, 'contact.form.name')}</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 border border-gray-300 rounded bg-white focus:ring-2 focus:ring-[#c67a4a] focus:border-[#c67a4a] outline-none transition-colors" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-[#2d3a2e] mb-1">{t(lang, 'contact.form.email')}</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-gray-300 rounded bg-white focus:ring-2 focus:ring-[#c67a4a] focus:border-[#c67a4a] outline-none transition-colors" />
            </div>
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-[#2d3a2e] mb-1">{t(lang, 'contact.form.phone')}</label>
            <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 border border-gray-300 rounded bg-white focus:ring-2 focus:ring-[#c67a4a] focus:border-[#c67a4a] outline-none transition-colors" />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-[#2d3a2e] mb-1">{t(lang, 'contact.form.message')}</label>
            <textarea id="message" name="message" rows="5" required placeholder={t(lang, 'contact.form.placeholder')} class="w-full px-4 py-3 border border-gray-300 rounded bg-white focus:ring-2 focus:ring-[#c67a4a] focus:border-[#c67a4a] outline-none transition-colors resize-vertical"></textarea>
          </div>
          <button type="submit" class="bg-[#c67a4a] text-white px-7 py-3 rounded font-semibold hover:bg-[#b06a3d] transition-colors text-sm uppercase tracking-wide">{t(lang, 'contact.form.submit')}</button>
        </form>
      </div>
      <div data-aos="fade-left">
        <span class="text-[#c67a4a] font-semibold text-sm uppercase tracking-wide">{t(lang, 'contact.map.label')}</span>
        <h2 class="text-2xl font-bold text-[#2d3a2e] mt-2 mb-6">{t(lang, 'contact.map.title')}</h2>
        <div class="rounded-lg overflow-hidden shadow-lg aspect-[4/3]">
          <iframe src="https://www.google.com/maps/embed?pb=!1m17!1m12!1m3!1d2964.5!2d24.902817!3d42.024696!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zNDLCsDAxJzI4LjkiTiAyNMKwNTQnMTAuMSJF!5e0!3m2!1sen!2sbg!4v1700000000000" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Kart 13 location"></iframe>
        </div>
        <div class="mt-4 bg-white rounded-lg p-5 shadow-sm">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#c67a4a] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <div>
              <p class="text-sm font-medium text-[#2d3a2e]">{t(lang, 'contact.hours.title')}</p>
              <p class="text-sm text-[#6b6560] mt-1">{t(lang, 'contact.hours.weekday')}</p>
              <p class="text-sm text-[#6b6560]">{t(lang, 'contact.hours.weekend')}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
