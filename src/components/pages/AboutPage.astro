---
import { t, type Lang } from '../../i18n/translations';
import { getLocalePath } from '../../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
---

<!-- Hero -->
<section class="relative h-[50vh] min-h-[400px] flex items-center">
  <div class="absolute inset-0">
    <img src="https://images.unsplash.com/photo-1676451727332-790e79f6cc59?fm=jpg&q=80&w=1920&auto=format&fit=crop" alt="" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-[#2d3a2e]/80"></div>
  </div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h1 class="text-4xl md:text-5xl font-bold text-white">{t(lang, 'about.hero.title')}</h1>
    <p class="mt-4 text-lg text-gray-200 max-w-xl">{t(lang, 'about.hero.desc')}</p>
  </div>
</section>

<!-- Story -->
<section class="py-20 bg-[#faf9f6]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-14 items-center">
      <div data-aos="fade-right">
        <img src="https://images.unsplash.com/photo-1730584475392-b633246fd486?fm=jpg&q=80&w=800&auto=format&fit=crop" alt="" class="rounded-lg shadow-lg w-full aspect-[4/3] object-cover" />
      </div>
      <div data-aos="fade-left">
        <span class="text-[#c67a4a] font-semibold text-sm uppercase tracking-wide">{t(lang, 'about.story.label')}</span>
        <h2 class="text-3xl font-bold text-[#2d3a2e] mt-2">{t(lang, 'about.story.title')}</h2>
        <p class="mt-5 text-[#6b6560] leading-relaxed">{t(lang, 'about.story.p1')}</p>
        <p class="mt-4 text-[#6b6560] leading-relaxed">{t(lang, 'about.story.p2')}</p>
        <p class="mt-4 text-[#6b6560] leading-relaxed">{t(lang, 'about.story.p3')}</p>
      </div>
    </div>
  </div>
</section>

<!-- Process -->
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center" data-aos="fade-up">
      <span class="text-[#c67a4a] font-semibold text-sm uppercase tracking-wide">{t(lang, 'about.process.label')}</span>
      <h2 class="text-3xl font-bold text-[#2d3a2e] mt-2">{t(lang, 'about.process.title')}</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-10 mt-14">
      <div class="relative" data-aos="fade-up" data-aos-delay="0">
        <div class="w-14 h-14 bg-[#2d3a2e] rounded-lg flex items-center justify-center">
          <span class="text-[#c67a4a] font-bold text-lg">01</span>
        </div>
        <h3 class="mt-5 font-bold text-[#2d3a2e] text-lg">{t(lang, 'about.process.1.title')}</h3>
        <p class="mt-2 text-[#6b6560] leading-relaxed">{t(lang, 'about.process.1.desc')}</p>
        <div class="hidden md:block absolute top-7 left-[calc(100%-20px)] w-[calc(100%-30px)] border-t-2 border-dashed border-gray-200"></div>
      </div>
      <div class="relative" data-aos="fade-up" data-aos-delay="150">
        <div class="w-14 h-14 bg-[#2d3a2e] rounded-lg flex items-center justify-center">
          <span class="text-[#c67a4a] font-bold text-lg">02</span>
        </div>
        <h3 class="mt-5 font-bold text-[#2d3a2e] text-lg">{t(lang, 'about.process.2.title')}</h3>
        <p class="mt-2 text-[#6b6560] leading-relaxed">{t(lang, 'about.process.2.desc')}</p>
        <div class="hidden md:block absolute top-7 left-[calc(100%-20px)] w-[calc(100%-30px)] border-t-2 border-dashed border-gray-200"></div>
      </div>
      <div data-aos="fade-up" data-aos-delay="300">
        <div class="w-14 h-14 bg-[#2d3a2e] rounded-lg flex items-center justify-center">
          <span class="text-[#c67a4a] font-bold text-lg">03</span>
        </div>
        <h3 class="mt-5 font-bold text-[#2d3a2e] text-lg">{t(lang, 'about.process.3.title')}</h3>
        <p class="mt-2 text-[#6b6560] leading-relaxed">{t(lang, 'about.process.3.desc')}</p>
      </div>
    </div>
  </div>
</section>

<!-- Facility -->
<section class="py-20 bg-[#2d3a2e]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center" data-aos="fade-up">
      <span class="text-[#c67a4a] font-semibold text-sm uppercase tracking-wide">{t(lang, 'about.facility.label')}</span>
      <h2 class="text-3xl font-bold text-white mt-2">{t(lang, 'about.facility.title')}</h2>
      <p class="mt-3 text-gray-300 max-w-lg mx-auto">{t(lang, 'about.facility.desc')}</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-12">
      <div class="bg-white/5 border border-white/10 p-7 rounded-lg" data-aos="fade-up" data-aos-delay="0">
        <div class="w-10 h-10 bg-[#c67a4a]/20 rounded flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-[#c67a4a]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
        </div>
        <h3 class="font-bold text-white">{t(lang, 'about.facility.extrusion')}</h3>
        <p class="text-sm text-gray-400 mt-2">{t(lang, 'about.facility.extrusion.desc')}</p>
      </div>
      <div class="bg-white/5 border border-white/10 p-7 rounded-lg" data-aos="fade-up" data-aos-delay="100">
        <div class="w-10 h-10 bg-[#c67a4a]/20 rounded flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-[#c67a4a]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>
        </div>
        <h3 class="font-bold text-white">{t(lang, 'about.facility.printing')}</h3>
        <p class="text-sm text-gray-400 mt-2">{t(lang, 'about.facility.printing.desc')}</p>
      </div>
      <div class="bg-white/5 border border-white/10 p-7 rounded-lg" data-aos="fade-up" data-aos-delay="200">
        <div class="w-10 h-10 bg-[#c67a4a]/20 rounded flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-[#c67a4a]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243 4.243 3 3 0 004.243-4.243zm0-5.758a3 3 0 10-4.243-4.243 3 3 0 004.243 4.243z" /></svg>
        </div>
        <h3 class="font-bold text-white">{t(lang, 'about.facility.cutting')}</h3>
        <p class="text-sm text-gray-400 mt-2">{t(lang, 'about.facility.cutting.desc')}</p>
      </div>
      <div class="bg-white/5 border border-white/10 p-7 rounded-lg" data-aos="fade-up" data-aos-delay="300">
        <div class="w-10 h-10 bg-[#c67a4a]/20 rounded flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-[#c67a4a]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <h3 class="font-bold text-white">{t(lang, 'about.facility.qc')}</h3>
        <p class="text-sm text-gray-400 mt-2">{t(lang, 'about.facility.qc.desc')}</p>
      </div>
    </div>
  </div>
</section>

<!-- Why us -->
<section class="py-20 bg-[#f5ebe0]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-14 items-center">
      <div data-aos="fade-right">
        <span class="text-[#c67a4a] font-semibold text-sm uppercase tracking-wide">{t(lang, 'about.why.label')}</span>
        <h2 class="text-3xl font-bold text-[#2d3a2e] mt-2">{t(lang, 'about.why.title')}</h2>
        <div class="mt-8 space-y-6">
          <div class="flex gap-4">
            <div class="w-1 bg-[#c67a4a] rounded-full flex-shrink-0"></div>
            <div><h3 class="font-bold text-[#2d3a2e]">{t(lang, 'about.why.direct')}</h3><p class="text-sm text-[#6b6560] mt-1">{t(lang, 'about.why.direct.desc')}</p></div>
          </div>
          <div class="flex gap-4">
            <div class="w-1 bg-[#c67a4a] rounded-full flex-shrink-0"></div>
            <div><h3 class="font-bold text-[#2d3a2e]">{t(lang, 'about.why.flexible')}</h3><p class="text-sm text-[#6b6560] mt-1">{t(lang, 'about.why.flexible.desc')}</p></div>
          </div>
          <div class="flex gap-4">
            <div class="w-1 bg-[#c67a4a] rounded-full flex-shrink-0"></div>
            <div><h3 class="font-bold text-[#2d3a2e]">{t(lang, 'about.why.word')}</h3><p class="text-sm text-[#6b6560] mt-1">{t(lang, 'about.why.word.desc')}</p></div>
          </div>
          <div class="flex gap-4">
            <div class="w-1 bg-[#c67a4a] rounded-full flex-shrink-0"></div>
            <div><h3 class="font-bold text-[#2d3a2e]">{t(lang, 'about.why.pricing')}</h3><p class="text-sm text-[#6b6560] mt-1">{t(lang, 'about.why.pricing.desc')}</p></div>
          </div>
        </div>
      </div>
      <div data-aos="fade-left">
        <img src="https://images.unsplash.com/photo-1675109786596-0c20239ad292?fm=jpg&q=80&w=800&auto=format&fit=crop&crop=right" alt="" class="rounded-lg shadow-lg w-full aspect-[4/3] object-cover" />
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-20 bg-[#2d3a2e]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-aos="fade-up">
    <h2 class="text-3xl font-bold text-white">{t(lang, 'about.cta.title')}</h2>
    <p class="mt-4 text-gray-300 max-w-lg mx-auto">{t(lang, 'about.cta.desc')}</p>
    <a href={getLocalePath(lang, '/request-quote')} class="mt-8 inline-block bg-[#c67a4a] text-white px-8 py-3.5 rounded font-semibold hover:bg-[#b06a3d] transition-colors text-sm uppercase tracking-wide">{t(lang, 'about.cta.btn')}</a>
  </div>
</section>
