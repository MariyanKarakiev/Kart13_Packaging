---
import { t, type Lang } from '../../i18n/translations';
import { getLocalePath } from '../../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
---

<!-- Hero -->
<section class="relative h-[85vh] min-h-[600px] flex items-center">
  <div class="absolute inset-0">
    <img src="https://images.unsplash.com/photo-1700727448686-b314cb5f9948?fm=jpg&q=80&w=1920&auto=format&fit=crop" alt="Plastic packaging production line" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-[#2d3a2e]/75"></div>
  </div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight max-w-2xl">
      {t(lang, 'home.hero.title')}
    </h1>
    {t(lang, 'home.hero.title2') && <p class="mt-3 text-xl md:text-2xl text-gray-100 font-medium max-w-xl">{t(lang, 'home.hero.title2')}</p>}
    <p class="mt-6 text-lg text-gray-200 max-w-xl leading-relaxed">{t(lang, 'home.hero.desc')}</p>
    <div class="mt-8 flex flex-wrap gap-4">
      <a href={getLocalePath(lang, '/request-quote')} class="bg-[#c67a4a] text-white px-7 py-3.5 rounded font-semibold hover:bg-[#b06a3d] transition-colors text-sm uppercase tracking-wide">{t(lang, 'home.hero.cta')}</a>
      <a href={getLocalePath(lang, '/products')} class="border-2 border-white/40 text-white px-7 py-3.5 rounded font-semibold hover:border-white hover:bg-white/10 transition-all text-sm uppercase tracking-wide">{t(lang, 'home.hero.cta2')}</a>
    </div>
  </div>
</section>

<!-- Stats -->
<section class="bg-[#2d3a2e] py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-4 gap-6 text-center">
      <div><div class="text-2xl font-bold text-[#c67a4a]">10+</div><div class="text-sm text-gray-300 mt-1">{t(lang, 'home.stats.years')}</div></div>
      <div><div class="text-2xl font-bold text-[#c67a4a]">{lang === 'bg' ? 'Собствени' : 'Own'}</div><div class="text-sm text-gray-300 mt-1">{t(lang, 'home.stats.facility')}</div></div>
      <div><div class="text-2xl font-bold text-[#c67a4a]">{lang === 'bg' ? 'Бързи' : 'Fast'}</div><div class="text-sm text-gray-300 mt-1">{t(lang, 'home.stats.fast')}</div></div>
      <div><div class="text-2xl font-bold text-[#c67a4a]">EU</div><div class="text-sm text-gray-300 mt-1">{t(lang, 'home.stats.eu')}</div></div>
    </div>
  </div>
</section>

<!-- Intro -->
<section class="py-20 bg-[#faf9f6]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div data-aos="fade-right">
        <img src="https://images.unsplash.com/photo-1676451727332-790e79f6cc59?fm=jpg&q=80&w=800&auto=format&fit=crop" alt="Packaging materials" class="rounded-lg shadow-lg w-full aspect-[4/3] object-cover" />
      </div>
      <div data-aos="fade-left">
        <h2 class="text-3xl font-bold text-[#2d3a2e]">{t(lang, 'home.intro.title')}</h2>
        <p class="mt-5 text-[#6b6560] leading-relaxed">{t(lang, 'home.intro.p1')}</p>
        <p class="mt-4 text-[#6b6560] leading-relaxed">{t(lang, 'home.intro.p2')}</p>
        <a href={getLocalePath(lang, '/about')} class="inline-block mt-6 text-[#c67a4a] font-semibold hover:text-[#b06a3d] transition-colors">{t(lang, 'home.intro.link')} &rarr;</a>
      </div>
    </div>
  </div>
</section>

<!-- Products -->
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14" data-aos="fade-up">
      <h2 class="text-3xl font-bold text-[#2d3a2e]">{t(lang, 'home.products.title')}</h2>
      <p class="mt-3 text-[#6b6560]">{t(lang, 'home.products.desc')}</p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <div class="group relative overflow-hidden rounded-lg" data-aos="fade-up" data-aos-delay="0">
        <img src="https://images.unsplash.com/photo-1675109786596-0c20239ad292?fm=jpg&q=80&w=600&auto=format&fit=crop" alt="Bags" class="w-full aspect-[4/3] object-cover group-hover:scale-105 transition-transform duration-500" />
        <div class="absolute inset-0 bg-gradient-to-t from-[#2d3a2e]/90 via-[#2d3a2e]/30 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6">
          <h3 class="text-xl font-bold text-white">{t(lang, 'home.products.bags')}</h3>
          <p class="text-sm text-gray-300 mt-1">{t(lang, 'home.products.bags.desc')}</p>
        </div>
      </div>
      <div class="group relative overflow-hidden rounded-lg" data-aos="fade-up" data-aos-delay="100">
        <img src="https://images.unsplash.com/photo-1730584475392-b633246fd486?fm=jpg&q=80&w=600&auto=format&fit=crop" alt="Films" class="w-full aspect-[4/3] object-cover group-hover:scale-105 transition-transform duration-500" />
        <div class="absolute inset-0 bg-gradient-to-t from-[#2d3a2e]/90 via-[#2d3a2e]/30 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6">
          <h3 class="text-xl font-bold text-white">{t(lang, 'home.products.films')}</h3>
          <p class="text-sm text-gray-300 mt-1">{t(lang, 'home.products.films.desc')}</p>
        </div>
      </div>
      <div class="group relative overflow-hidden rounded-lg" data-aos="fade-up" data-aos-delay="200">
        <img src="https://images.unsplash.com/photo-1777464375799-768774f30542?fm=jpg&q=80&w=600&auto=format&fit=crop" alt="Custom" class="w-full aspect-[4/3] object-cover group-hover:scale-105 transition-transform duration-500" />
        <div class="absolute inset-0 bg-gradient-to-t from-[#2d3a2e]/90 via-[#2d3a2e]/30 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6">
          <h3 class="text-xl font-bold text-white">{t(lang, 'home.products.custom')}</h3>
          <p class="text-sm text-gray-300 mt-1">{t(lang, 'home.products.custom.desc')}</p>
        </div>
      </div>
    </div>
    <div class="text-center mt-10">
      <a href={getLocalePath(lang, '/products')} class="text-[#c67a4a] font-semibold hover:text-[#b06a3d] transition-colors">{t(lang, 'home.products.link')} &rarr;</a>
    </div>
  </div>
</section>

<!-- Why us -->
<section class="py-20 bg-[#f5ebe0]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div data-aos="fade-right">
        <h2 class="text-3xl font-bold text-[#2d3a2e]">{t(lang, 'home.why.title')}</h2>
        <div class="mt-8 space-y-6">
          <div class="flex gap-4">
            <div class="w-10 h-10 bg-[#2d3a2e] rounded flex items-center justify-center flex-shrink-0"><span class="text-[#c67a4a] font-bold text-sm">01</span></div>
            <div><h3 class="font-semibold text-[#2d3a2e]">{t(lang, 'home.why.1.title')}</h3><p class="text-sm text-[#6b6560] mt-1">{t(lang, 'home.why.1.desc')}</p></div>
          </div>
          <div class="flex gap-4">
            <div class="w-10 h-10 bg-[#2d3a2e] rounded flex items-center justify-center flex-shrink-0"><span class="text-[#c67a4a] font-bold text-sm">02</span></div>
            <div><h3 class="font-semibold text-[#2d3a2e]">{t(lang, 'home.why.2.title')}</h3><p class="text-sm text-[#6b6560] mt-1">{t(lang, 'home.why.2.desc')}</p></div>
          </div>
          <div class="flex gap-4">
            <div class="w-10 h-10 bg-[#2d3a2e] rounded flex items-center justify-center flex-shrink-0"><span class="text-[#c67a4a] font-bold text-sm">03</span></div>
            <div><h3 class="font-semibold text-[#2d3a2e]">{t(lang, 'home.why.3.title')}</h3><p class="text-sm text-[#6b6560] mt-1">{t(lang, 'home.why.3.desc')}</p></div>
          </div>
        </div>
      </div>
      <div data-aos="fade-left">
        <img src="https://images.unsplash.com/photo-1675109786596-0c20239ad292?fm=jpg&q=80&w=800&auto=format&fit=crop&crop=right" alt="Production floor" class="rounded-lg shadow-lg w-full aspect-[4/3] object-cover" />
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-20 bg-[#2d3a2e]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-aos="fade-up">
    <h2 class="text-3xl font-bold text-white">{t(lang, 'home.cta.title')}</h2>
    <p class="mt-4 text-gray-300 max-w-lg mx-auto">{t(lang, 'home.cta.desc')}</p>
    <a href={getLocalePath(lang, '/request-quote')} class="mt-8 inline-block bg-[#c67a4a] text-white px-8 py-3.5 rounded font-semibold hover:bg-[#b06a3d] transition-colors text-sm uppercase tracking-wide">{t(lang, 'home.cta.btn')}</a>
  </div>
</section>
